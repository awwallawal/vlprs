# Auditor Station configuration.
# Copy this file to ".env" (same folder) and edit. ".env" is gitignored — your PIN never
# commits and never rides in the shared bundle. Set the PIN on the auditor's laptop.
#
#   cp .env.example .env      (then edit STATION_PIN)
#
# Restart the station (pnpm start) after changing anything here.

# Access PIN. Ask the auditor what they want, put it here.
# Leave BLANK or remove the line = station is OPEN (no PIN). To change it: edit and restart.
# To remove it: clear the value (or delete .env) and restart.
STATION_PIN=

# --- Optional overrides (sensible defaults apply if omitted) ---
# STATION_PORT=8717
# STATION_MODEL=qwen2.5:7b
# STATION_OLLAMA_URL=http://localhost:11434
