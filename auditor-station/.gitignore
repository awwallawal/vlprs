# Auditor Station — self-contained .gitignore (travels with the folder).
# PII NEVER gets committed: the catalog DB and the local audit log are gitignored.

# Toolchain
node_modules/
dist/
*.tsbuildinfo
*.log

# PII — citizen financial data (built/copied locally, never to git).
# Keep the dirs as structure; ignore everything inside them.
data/*
!data/.gitkeep
audit/*
!audit/.gitkeep

# OS
.DS_Store
Thumbs.db
